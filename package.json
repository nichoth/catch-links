{
  "name": "@nichoth/catch-links",
  "version": "0.0.0",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "build-cjs": "mkdir -p dist && esbuild index.js --bundle --outfile=dist/index.js",
    "test": "npm run test-unit && npm run test-browser",
    "test-unit": "tape test/unit.js | tap-arc",
    "test-browser": "browserify test/index.js | htmlify test/index.html | tape-run --input=html | tap-arc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nichoth/catch-links.git"
  },
  "keywords": [
    "catch",
    "links"
  ],
  "author": "nichoth",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nichoth/catch-links/issues"
  },
  "homepage": "https://github.com/nichoth/catch-links#readme",
  "description": "",
  "devDependencies": {
    "@socketsupply/test-dom": "^0.4.1",
    "browserify": "^17.0.0",
    "esbuild": "^0.15.13",
    "inline-htmlify": "^2.0.1",
    "tap-arc": "^0.3.5",
    "tape": "^5.6.1",
    "tape-run": "^10.0.0"
  }
}
